@model IEnumerable<Cinema.Presentation.Models.SepetDto>
@{
    ViewData["Title"] = "Sepetim";
}

<div class="game-details">
    <div class="heading-section">
        <h4><em>Sepetim</em></h4>
    </div>
    @if (!Model.Any())
    {
        <p>Sepetiniz boş.</p>
    }
    else
    {
        <table class="table" style="color:#fff; width:100%;">
            <thead>
                <tr>
                    <th>Film</th>
                    <th>Salon</th>
                    <th>Seans</th>
                    <th>Bilet Tipi</th>
                    <th>Adet</th>
                    <th>Fiyat</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FilmTitle</td>
                        <td>@item.SalonName</td>
                        <td>@item.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@item.BiletTipi</td>
                        <td>@item.Quantity</td>
                        <td>@((item.Quantity * item.UnitPrice).ToString("C"))</td>
                        <td>
                            <form method="post" asp-action="Sil">
                                <input type="hidden" name="sepetId" value="@item.Id" />
                                <div class="main-border-button" style="margin-top:-5px;">
                                    <button type="submit">Sil</button>
                                </div>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="main-button mt-3">
            <a asp-action="Odeme">Ödemeye Geç</a>
        </div>
    }
</div>