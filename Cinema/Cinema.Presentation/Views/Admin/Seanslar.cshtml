@model IEnumerable<Cinema.Presentation.Models.SeansDto>
@{
    ViewData["Title"] = "Seanslar";
}

<div class="glass-card">
    <div class="card-header">
        <div>
            <h2 class="card-title">Seans Listesi</h2>
        </div>
        <div class="card-actions">
            <a asp-action="SeansEkle" class="card-btn">Yeni Seans Ekle</a>
        </div>
    </div>
    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Film</th>
                    <th>Salon</th>
                    <th>Konum</th>
                    <th>Saat</th>
                    <th>Fiyat</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var seans in Model)
                {
                    <tr>
                        <td>@seans.FilmTitle</td>
                        <td>@seans.SalonName</td>
                        <td>@seans.City</td>
                        <td>@seans.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@seans.Price.ToString("C")</td>
                        <td>
                            <form method="post" asp-action="SeansSil">
                                <input type="hidden" name="id" value="@seans.Id" />
                                <button type="submit" class="card-btn">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>